  src: url("{{ 'aeonik-italic.woff2' | asset_url }}") format("woff2");
  font-weight: 400; font-style: italic; font-display: swap;
}
@font-face {
  font-family: "Aeonik";
  src: url("{{ 'aeonik-medium.woff2' | asset_url }}") format("woff2");
  font-weight: 500; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "Aeonik";
  src: url("{{ 'aeonik-medium-italic.woff2' | asset_url }}") format("woff2");
  font-weight: 500; font-style: italic; font-display: swap;
}
@font-face {
  font-family: "Aeonik";
  src: url("{{ 'aeonik-bold.woff2' | asset_url }}") format("woff2");
  font-weight: 700; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "Aeonik";
  src: url("{{ 'aeonik-bold-italic.woff2' | asset_url }}") format("woff2");
  font-weight: 700; font-style: italic; font-display: swap;
}

/* Aeonik Condensed (small uppercase labels) */
@font-face {
  font-family: "Aeonik Condensed";
  src: url("{{ 'aeonik-condensed-regular.woff2' | asset_url }}") format("woff2");
  font-weight: 400; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "Aeonik Condensed";
  src: url("{{ 'aeonik-condensed-italic.woff2' | asset_url }}") format("woff2");
  font-weight: 400; font-style: italic; font-display: swap;
}
@font-face {
  font-family: "Aeonik Condensed";
  src: url("{{ 'aeonik-condensed-semibold.woff2' | asset_url }}") format("woff2");
  font-weight: 600; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "Aeonik Condensed";
  src: url("{{ 'aeonik-condensed-semibold-italic.woff2' | asset_url }}") format("woff2");
  font-weight: 600; font-style: italic; font-display: swap;
}
@font-face {
  font-family: "Aeonik Condensed";
  src: url("{{ 'aeonik-condensed-bold.woff2' | asset_url }}") format("woff2");
  font-weight: 700; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "Aeonik Condensed";
  src: url("{{ 'aeonik-condensed-bold-italic.woff2' | asset_url }}") format("woff2");
  font-weight: 700; font-style: italic; font-display: swap;
}

/* Scope variables to this page only */
.ds-lions-mane {
  --ink: #0A0A0A;
  --ink-soft: #1f1f1f;
  --muted: #555;
  --line: #E5E5E5;
  --bg: #fff;
  --bg-soft: #F5F5F4;
  --purple-soft: #EDE5FF;
  --radius: 18px;
  --max: 1100px;

  font-family: "Aeonik", -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Helvetica, Arial, sans-serif;
  color: var(--ink);
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  background: var(--bg);
}
.ds-lions-mane *,
.ds-lions-mane *::before,
.ds-lions-mane *::after { box-sizing: border-box; }
.ds-lions-mane h1,
.ds-lions-mane h2,
.ds-lions-mane h3,
.ds-lions-mane h4 { margin: 0; font-weight: 700; letter-spacing: -0.01em; color: var(--ink); }
.ds-lions-mane p { color: var(--ink-soft); margin: 0 0 16px 0; }
.ds-lions-mane a { color: var(--ink); }

.ds-lions-mane .study-meta,
.ds-lions-mane .mechanism-eyebrow,
.ds-lions-mane .dose-cell-label,
.ds-lions-mane .focus-block h3 {
  font-family: "Aeonik Condensed", "Aeonik", -apple-system, BlinkMacSystemFont, sans-serif;
}

.ds-lions-mane .wrap { max-width: var(--max); margin: 0 auto; padding: 72px 32px; }
.ds-lions-mane section { margin-bottom: 112px; }

/* Button */
.ds-lions-mane .btn {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--ink); color: #fff; text-decoration: none;
  padding: 14px 28px; border-radius: 999px;
  font-weight: 600; font-size: 0.95rem;
  transition: transform 0.15s ease, background 0.15s ease;
}
.ds-lions-mane .btn:hover { background: #000; transform: translateY(-1px); }
.ds-lions-mane .btn .arrow { transition: transform 0.15s ease; }
.ds-lions-mane .btn:hover .arrow { transform: translateX(3px); }

/* Hero */
.ds-lions-mane .hero {
  display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center;
}
.ds-lions-mane .hero-eyebrow {
  font-style: italic; font-weight: 700; color: var(--ink);
  margin: 0 0 20px 0; font-size: 1.05rem;
}
.ds-lions-mane .hero-title {
  font-size: 3.4rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: -0.015em; line-height: 1; margin: 0 0 14px 0;
}
.ds-lions-mane .hero-body p { font-size: 1rem; line-height: 1.65; }
.ds-lions-mane .hero-image {
  width: 100%; height: auto; max-height: 540px;
  border-radius: var(--radius); object-fit: contain; background: #fff;
}

/* Mechanism */
.ds-lions-mane .mechanism { text-align: center; }
.ds-lions-mane .mechanism h2 { text-transform: uppercase; font-size: 2rem; margin-bottom: 16px; }
.ds-lions-mane .mechanism-intro { color: var(--muted); max-width: 620px; margin: 0 auto 40px; }
.ds-lions-mane .mechanism-card {
  background: var(--purple-soft); border-radius: var(--radius);
  padding: 56px; text-align: left;
}
.ds-lions-mane .mechanism-points { display: grid; gap: 24px; }
.ds-lions-mane .point-num { display: inline-block; color: var(--ink); font-weight: 700; margin-right: 4px; }
.ds-lions-mane .point h4 { font-size: 1rem; margin: 0 0 4px 0; font-weight: 700; }
.ds-lions-mane .point p { margin: 0; color: var(--ink-soft); font-size: 0.97rem; line-height: 1.6; }
.ds-lions-mane .mechanism-footnote { font-size: 0.82rem; color: var(--muted); margin: 32px auto 0; }
.ds-lions-mane .mechanism-footnote em { color: var(--ink); }

/* Why we use it */
.ds-lions-mane .split {
  display: grid; grid-template-columns: 1fr 1.1fr; gap: 64px; align-items: center;
}
.ds-lions-mane .split-image {
  width: 100%; height: auto; max-height: 480px;
  object-fit: contain; border-radius: var(--radius); background: #fff;
}
.ds-lions-mane .split h2 { text-transform: uppercase; font-size: 1.7rem; margin-bottom: 16px; }
.ds-lions-mane .focus-block { margin-top: 28px; }
.ds-lions-mane .focus-block h3 {
  text-transform: uppercase; font-size: 0.95rem; margin-bottom: 14px;
  font-weight: 700; letter-spacing: 0.04em;
}
.ds-lions-mane .focus-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
.ds-lions-mane .focus-list li {
  display: flex; align-items: center; gap: 12px;
  color: var(--ink-soft); font-size: 1rem;
}
.ds-lions-mane .focus-list li::before {
  content: ""; width: 18px; height: 18px; flex: 0 0 18px;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20' fill='none' stroke='%230A0A0A' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><polyline points='4 11 8 15 16 5'/></svg>");
  background-size: contain; background-repeat: no-repeat;
}

/* Dose comparison */
.ds-lions-mane .dose h2 { text-transform: uppercase; font-size: 1.7rem; margin-bottom: 8px; }
.ds-lions-mane .dose-sub { color: var(--muted); margin-bottom: 32px; }
.ds-lions-mane .dose-table {
  display: grid; grid-template-columns: repeat(3, 1fr);
  border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden;
}
.ds-lions-mane .dose-cell { padding: 32px 28px; border-right: 1px solid var(--line); }
.ds-lions-mane .dose-cell:last-child { border-right: none; }
.ds-lions-mane .dose-cell-label {
  font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em;
  color: var(--muted); font-weight: 600; margin-bottom: 12px;
}
.ds-lions-mane .dose-cell-value { font-size: 1.4rem; font-weight: 600; color: var(--ink); }
.ds-lions-mane .dose-cell.highlight { background: #FFD9B3; }
.ds-lions-mane .dose-cell.highlight .dose-cell-label { color: var(--ink); font-weight: 700; opacity: 0.75; }
.ds-lions-mane .dose-cell.highlight .dose-cell-value { font-weight: 800; font-size: 1.7rem; }
.ds-lions-mane .dose-note { font-size: 0.82rem; color: var(--muted); margin-top: 16px; }

/* Studies */
.ds-lions-mane .learn { text-align: center; margin-bottom: 80px; }
.ds-lions-mane .learn h2 { text-transform: uppercase; font-size: 2rem; margin-bottom: 16px; }
.ds-lions-mane .learn-intro { color: var(--muted); max-width: 600px; margin: 0 auto 40px; }
.ds-lions-mane .study-grid {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; text-align: left;
}
.ds-lions-mane .study {
  display: block; padding: 26px 28px; border: 1px solid var(--line);
  border-radius: 14px; text-decoration: none; background: #fff;
  transition: border-color 0.15s ease, transform 0.15s ease;
}
.ds-lions-mane .study:hover { border-color: var(--ink); transform: translateY(-2px); }
.ds-lions-mane .study-meta {
  font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em;
  color: var(--muted); font-weight: 700; margin-bottom: 10px;
}
.ds-lions-mane .study-title {
  font-size: 1rem; font-weight: 700; color: var(--ink);
  margin-bottom: 8px; line-height: 1.4;
}
.ds-lions-mane .study-desc {
  font-size: 0.9rem; color: var(--muted); line-height: 1.55; margin: 0 0 14px 0;
}
.ds-lions-mane .study-arrow {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 0.85rem; color: var(--ink); font-weight: 600;
}

/* Final CTA */
.ds-lions-mane .cta-wrap {
  text-align: center; padding: 72px 32px; border-radius: var(--radius); margin-bottom: 64px;
  background: linear-gradient(135deg, #FFD9DC 0%, #F8B7C5 50%, #F5A0B8 100%);
}
.ds-lions-mane .cta-wrap h2 {
  text-transform: uppercase; font-size: 2rem; margin-bottom: 12px; color: var(--ink);
}
.ds-lions-mane .cta-wrap p { color: var(--ink-soft); margin-bottom: 28px; }

/* Ingredient nav */
.ds-lions-mane .ingredient-nav {
  display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 40px;
}
.ds-lions-mane .ingredient-nav a {
  display: inline-block; padding: 8px 16px; border-radius: 999px;
  background: var(--bg-soft); color: var(--ink-soft); text-decoration: none;
  font-size: 0.85rem; font-weight: 500; border: 1px solid transparent;
  transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
}
.ds-lions-mane .ingredient-nav a:hover {
  background: #fff; border-color: var(--ink); color: var(--ink);
}

@media (max-width: 820px) {
  .ds-lions-mane .wrap { padding: 56px 22px; }
  .ds-lions-mane section { margin-bottom: 80px; }
  .ds-lions-mane .hero,
  .ds-lions-mane .split { grid-template-columns: 1fr; gap: 32px; }
  .ds-lions-mane .hero-title { font-size: 2.4rem; }
  .ds-lions-mane .mechanism h2,
  .ds-lions-mane .learn h2,
  .ds-lions-mane .cta-wrap h2 { font-size: 1.6rem; }
  .ds-lions-mane .mechanism-card { padding: 32px 24px; }
  .ds-lions-mane .dose-table { grid-template-columns: 1fr; }
  .ds-lions-mane .dose-cell { border-right: none; border-bottom: 1px solid var(--line); }
  .ds-lions-mane .dose-cell:last-child { border-bottom: none; }
  .ds-lions-mane .study-grid { grid-template-columns: 1fr; }
  .ds-lions-mane .cta-wrap { padding: 48px 22px; }

/* ============================================
   OVERRIDES — beats theme's global body{font-weight:normal !important}
   Scoped to .ds-lions-mane only.
   ============================================ */

.ds-lions-mane,
.ds-lions-mane *,
.ds-lions-mane *::before,
.ds-lions-mane *::after {
  font-family: "Aeonik", -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Helvetica, Arial, sans-serif !important;
}

.ds-lions-mane .study-meta,
.ds-lions-mane .mechanism-eyebrow,
.ds-lions-mane .dose-cell-label,
.ds-lions-mane .focus-block h3 {
  font-family: "Aeonik Condensed", "Aeonik", -apple-system, BlinkMacSystemFont, sans-serif !important;
}

.ds-lions-mane h1,
.ds-lions-mane h2,
.ds-lions-mane h3,
.ds-lions-mane h4,
.ds-lions-mane strong,
.ds-lions-mane b { font-weight: 700 !important; }

.ds-lions-mane .hero-title { font-weight: 800 !important; }
.ds-lions-mane .hero-eyebrow { font-weight: 700 !important; font-style: italic !important; }
.ds-lions-mane .point h4,
.ds-lions-mane .point-num,
.ds-lions-mane .study-title,
.ds-lions-mane .focus-block h3,
.ds-lions-mane .mechanism-eyebrow,
.ds-lions-mane .study-meta { font-weight: 700 !important; }
.ds-lions-mane .dose-cell-label { font-weight: 600 !important; }
.ds-lions-mane .dose-cell-value { font-weight: 600 !important; }
.ds-lions-mane .dose-cell.highlight .dose-cell-label { font-weight: 700 !important; }
.ds-lions-mane .dose-cell.highlight .dose-cell-value { font-weight: 800 !important; }
.ds-lions-mane .btn { font-weight: 600 !important; }
.ds-lions-mane .ingredient-nav a { font-weight: 500 !important; }
.ds-lions-mane .study-arrow { font-weight: 600 !important; }
.ds-lions-mane p { font-weight: 400 !important; }
.ds-lions-mane em,
.ds-lions-mane i { font-style: italic !important; }
}
