{% comment %} DayShift — Comparison Table v2 {% endcomment %}

<section class="ds-compare" id="ds-compare-{{ section.id }}">
  <div class="page-width">
    <div class="ds-compare__header">
      {% if section.settings.eyebrow != blank %}
        <span class="ds-compare__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="ds-compare__heading">{{ section.settings.heading }}</h2>
    </div>

    {%- assign competitors = section.blocks | where: 'type', 'competitor' -%}
    {%- assign features = section.blocks | where: 'type', 'feature' -%}

    <div class="ds-compare__table-wrap">
      <table class="ds-compare__table">
        <thead>
          <tr>
            <th class="ds-compare__th ds-compare__th--label"></th>
            <th class="ds-compare__th ds-compare__th--dayshift">
              <span class="ds-compare__brand-name">DayShift</span>
            </th>
            {% for block in competitors %}
              <th class="ds-compare__th ds-compare__th--comp" {{ block.shopify_attributes }}>{{ block.settings.name }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for block in features %}
            <tr class="ds-compare__row" {{ block.shopify_attributes }}>
              <td class="ds-compare__td ds-compare__td--label">{{ block.settings.label }}</td>
              <td class="ds-compare__td ds-compare__td--dayshift">
                <span class="ds-compare__check ds-compare__check--yes" aria-label="Yes">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="currentColor" opacity="0.15"/><path d="M5 8L7.2 10.5L11 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </td>
              {%- assign comp_vals = block.settings.competitor_values | split: ', ' -%}
              {% for val in comp_vals %}
                <td class="ds-compare__td ds-compare__td--comp">
                  {% if val == 'yes' %}
                    <span class="ds-compare__check ds-compare__check--yes" aria-label="Yes">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="currentColor" opacity="0.15"/><path d="M5 8L7.2 10.5L11 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  {% elsif val == 'partial' %}
                    <span class="ds-compare__check ds-compare__check--partial" aria-label="Partial">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="currentColor" opacity="0.15"/><path d="M5 8h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </span>
                  {% else %}
                    <span class="ds-compare__check ds-compare__check--no" aria-label="No">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="currentColor" opacity="0.1"/><path d="M5.5 5.5l5 5M10.5 5.5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </span>
                  {% endif %}
                </td>
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if section.settings.cta_label != blank %}
      <div class="ds-compare__cta">
        <a href="{{ section.settings.cta_url }}" class="ds-compare__cta-btn">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .ds-compare {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .ds-compare__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .ds-compare__eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 0.875rem;
    opacity: 0.6;
  }

  .ds-compare__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: {{ section.settings.heading_color }};
    margin: 0;
  }

  .ds-compare__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 16px;
    border: 1px solid {{ section.settings.border_color }};
  }

  .ds-compare__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    min-width: 500px;
  }

  .ds-compare__th {
    padding: 1rem 1.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid {{ section.settings.border_color }};
    text-align: center;
    white-space: nowrap;
  }

  .ds-compare__th--label {
    text-align: left;
    background: {{ section.settings.background_color }};
    color: {{ section.settings.body_color }};
    width: 40%;
  }

  .ds-compare__th--dayshift {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
  }

  .ds-compare__th--comp {
    background: {{ section.settings.header_background }};
    color: {{ section.settings.body_color }};
  }

  .ds-compare__brand-name {
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .ds-compare__row:last-child .ds-compare__td { border-bottom: none; }

  .ds-compare__td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid {{ section.settings.border_color }};
    text-align: center;
    vertical-align: middle;
  }

  .ds-compare__td--label {
    text-align: left;
    font-size: 0.9375rem;
    font-weight: 500;
    color: {{ section.settings.heading_color }};
    background: {{ section.settings.background_color }};
  }

  .ds-compare__td--dayshift {
    background: color-mix(in srgb, {{ section.settings.heading_color }} 4%, {{ section.settings.background_color }});
  }

  .ds-compare__td--comp { background: {{ section.settings.background_color }}; }

  .ds-compare__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ds-compare__check--yes { color: #22c55e; }
  .ds-compare__check--partial { color: #f59e0b; }
  .ds-compare__check--no { color: #888888; }

  .ds-compare__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  .ds-compare__cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2.25rem;
    border-radius: 100px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
    transition: opacity 0.2s;
  }

  .ds-compare__cta-btn:hover { opacity: 0.85; }
</style>

{% schema %}
{
  "name": "Comparison Table",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why DayShift" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Not All Focus Is Created Equal" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Try DayShift Today" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "header_background", "label": "Competitor header bg", "default": "#f7f7f5" },
    { "type": "color", "id": "heading_color", "label": "Heading / DayShift color", "default": "#0a0a0a" },
    { "type": "color", "id": "body_color", "label": "Body color", "default": "#888888" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#888888" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#e5e5e5" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 80 }
  ],
  "blocks": [
    {
      "type": "competitor",
      "name": "Competitor Column",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "name", "label": "Competitor name", "default": "Energy Drinks" }
      ]
    },
    {
      "type": "feature",
      "name": "Feature Row",
      "settings": [
        { "type": "text", "id": "label", "label": "Feature label", "default": "Clinically dosed" },
        { "type": "text", "id": "dayshift_value", "label": "DayShift value (yes/no/partial)", "default": "yes" },
        { "type": "text", "id": "competitor_values", "label": "Competitor values (comma-separated: yes/no/partial)", "default": "no, no, partial" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        { "type": "competitor", "settings": { "name": "Energy Drinks" } },
        { "type": "competitor", "settings": { "name": "Coffee" } },
        { "type": "competitor", "settings": { "name": "Other Nootropics" } },
        { "type": "feature", "settings": { "label": "Clinically dosed ingredients", "dayshift_value": "yes", "competitor_values": "no, no, partial" } },
        { "type": "feature", "settings": { "label": "No artificial flavors", "dayshift_value": "yes", "competitor_values": "no, yes, partial" } },
        { "type": "feature", "settings": { "label": "No crash", "dayshift_value": "yes", "competitor_values": "no, no, yes" } },
        { "type": "feature", "settings": { "label": "Long-term cognitive support", "dayshift_value": "yes", "competitor_values": "no, no, partial" } },
        { "type": "feature", "settings": { "label": "5-day workday protocol", "dayshift_value": "yes", "competitor_values": "no, no, no" } },
        { "type": "feature", "settings": { "label": "Portable sachet format", "dayshift_value": "yes", "competitor_values": "yes, no, no" } }
      ]
    }
  ]
}
{% endschema %}
