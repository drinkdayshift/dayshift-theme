{% comment %} DayShift — Founder Section v2 {% endcomment %}

<section class="ds-founder" id="ds-founder-{{ section.id }}">
  <div class="page-width ds-founder__inner">
    <div class="ds-founder__image-col">
      {% if section.settings.founder_image != blank %}
        {{ section.settings.founder_image | image_url: width: 800 | image_tag:
          loading: 'lazy',
          alt: section.settings.founder_name,
          class: 'ds-founder__img',
          widths: '400, 600, 800'
        }}
      {% else %}
        <div class="ds-founder__img-placeholder">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="18" r="10" fill="currentColor" opacity="0.15"/>
            <path d="M4 44c0-11 9-18 20-18s20 7 20 18" fill="currentColor" opacity="0.1"/>
          </svg>
          <p>Founder photo</p>
        </div>
      {% endif %}
    </div>

    <div class="ds-founder__copy">
      {% if section.settings.eyebrow != blank %}
        <span class="ds-founder__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="ds-founder__heading">{{ section.settings.heading }}</h2>
      <div class="ds-founder__body">{{ section.settings.body }}</div>
      <div class="ds-founder__sig">
        <span class="ds-founder__name">— {{ section.settings.founder_name }}</span>
        {% if section.settings.founder_title != blank %}
          <span class="ds-founder__title">{{ section.settings.founder_title }}</span>
        {% endif %}
      </div>
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_url }}" class="ds-founder__cta">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .ds-founder {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    border-top: 1px solid {{ section.settings.divider_color }};
    border-bottom: 1px solid {{ section.settings.divider_color }};
  }

  .ds-founder__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .ds-founder__image-col { position: relative; }

  .ds-founder__img {
    width: 100%;
    border-radius: 16px;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  .ds-founder__img-placeholder {
    aspect-ratio: 4/5;
    border-radius: 16px;
    border: 1.5px dashed {{ section.settings.divider_color }};
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: {{ section.settings.body_color }};
    font-size: 0.875rem;
  }

  .ds-founder__img-placeholder p { margin: 0; }

  .ds-founder__eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 1rem;
    opacity: 0.6;
  }

  .ds-founder__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1.5rem;
    line-height: 1.15;
  }

  .ds-founder__body {
    font-size: 1rem;
    line-height: 1.75;
    color: {{ section.settings.body_color }};
    margin-bottom: 1.75rem;
  }

  .ds-founder__body p { margin: 0 0 1rem; }
  .ds-founder__body p:last-child { margin: 0; }

  .ds-founder__sig {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.25rem 0;
    border-top: 1px solid {{ section.settings.divider_color }};
    margin-bottom: 1.75rem;
  }

  .ds-founder__name {
    font-size: 1rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
  }

  .ds-founder__title {
    font-size: 0.8125rem;
    color: {{ section.settings.body_color }};
  }

  .ds-founder__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    border-radius: 100px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
    transition: opacity 0.2s;
  }

  .ds-founder__cta:hover { opacity: 0.85; }

  @media (max-width: 768px) {
    .ds-founder__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .ds-founder__image-col {
      max-width: 320px;
      margin: 0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "Founder",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the Founder" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built Because Nothing Else Worked" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>I built DayShift after years of testing every supplement, energy drink, and nootropic stack I could find. Most were either underdosed, full of junk, or just didn't work when I needed them most.</p><p>The idea was simple: what if the thing you reach for every morning was actually built around the science, not the marketing? That's DayShift.</p>" },
    { "type": "text", "id": "founder_name", "label": "Founder name", "default": "Jack" },
    { "type": "text", "id": "founder_title", "label": "Founder title", "default": "Founder, DayShift" },
    { "type": "image_picker", "id": "founder_image", "label": "Founder photo" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Try DayShift" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#0a0a0a" },
    { "type": "color", "id": "body_color", "label": "Body color", "default": "#666666" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#888888" },
    { "type": "color", "id": "divider_color", "label": "Divider color", "default": "#e5e5e5" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 96 }
  ],
  "presets": [{ "name": "Founder" }]
}
{% endschema %}
