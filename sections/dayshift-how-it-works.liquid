{% comment %} DayShift — How It Works v2 {% endcomment %}

<section class="ds-hiw" id="ds-hiw-{{ section.id }}">
  <div class="page-width">
    <div class="ds-hiw__header">
      {% if section.settings.eyebrow != blank %}
        <span class="ds-hiw__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="ds-hiw__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="ds-hiw__steps">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
          <div class="ds-hiw__step" {{ block.shopify_attributes }}>
            <div class="ds-hiw__step-number">{{ forloop.index }}</div>
            <div class="ds-hiw__step-body">
              <h3 class="ds-hiw__step-title">{{ block.settings.title }}</h3>
              <p class="ds-hiw__step-desc">{{ block.settings.description }}</p>
            </div>
          </div>
          {% unless forloop.last %}
            <div class="ds-hiw__connector" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.cta_label != blank %}
      <div class="ds-hiw__cta">
        <a href="{{ section.settings.cta_url }}" class="ds-hiw__cta-btn">{{ section.settings.cta_label }}</a>
        {% if section.settings.cta_note != blank %}
          <p class="ds-hiw__cta-note">{{ section.settings.cta_note }}</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .ds-hiw {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .ds-hiw__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .ds-hiw__eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 0.875rem;
    opacity: 0.6;
  }

  .ds-hiw__heading {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.1;
  }

  .ds-hiw__steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    max-width: 900px;
    margin: 0 auto;
  }

  .ds-hiw__step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    padding: 0 1.5rem;
  }

  .ds-hiw__step-number {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1.5px solid {{ section.settings.divider_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.125rem;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }

  .ds-hiw__step-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .ds-hiw__step-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: {{ section.settings.body_color }};
    margin: 0;
  }

  .ds-hiw__connector {
    display: flex;
    align-items: center;
    padding-top: 1rem;
    color: {{ section.settings.divider_color }};
    flex-shrink: 0;
  }

  .ds-hiw__cta {
    text-align: center;
    margin-top: 3rem;
  }

  .ds-hiw__cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2.25rem;
    border-radius: 100px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
    transition: opacity 0.2s;
  }

  .ds-hiw__cta-btn:hover { opacity: 0.85; }

  .ds-hiw__cta-note {
    margin: 0.75rem 0 0;
    font-size: 0.8125rem;
    color: {{ section.settings.body_color }};
  }

  @media (max-width: 680px) {
    .ds-hiw__steps {
      flex-direction: column;
      align-items: center;
    }

    .ds-hiw__step {
      flex-direction: row;
      text-align: left;
      padding: 1.5rem 0;
      border-bottom: 1px solid {{ section.settings.divider_color }};
      width: 100%;
      max-width: 400px;
    }

    .ds-hiw__step:last-child { border-bottom: none; }

    .ds-hiw__step-body { flex: 1; }

    .ds-hiw__connector { display: none; }
  }
</style>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Simple by Design" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How It Works" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop Now" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "text", "id": "cta_note", "label": "CTA note", "default": "Free shipping on all orders." },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#0a0a0a" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "body_color", "label": "Body color", "default": "#888888" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#ffffff" },
    { "type": "color", "id": "divider_color", "label": "Divider / border color", "default": "#2a2a2a" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 96 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Pour Into Water" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Tear open one sachet and pour the 12ml liquid into 12–16oz of cold water." }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "Pour Into Water", "description": "Tear open one sachet and pour the 12ml liquid into 12–16oz of cold water." } },
        { "type": "step", "settings": { "title": "Give It a Quick Shake", "description": "Shake or stir for a few seconds. No blender, no prep, no mess." } },
        { "type": "step", "settings": { "title": "Feel The Shift", "description": "Within minutes, a clean focused lift begins. No jitters. No crash. Just on." } }
      ]
    }
  ]
}
{% endschema %}