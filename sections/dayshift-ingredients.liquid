{% comment %} DayShift — Ingredients Carousel with Modal {% endcomment %}

<section class="ds-ingredients" id="ds-ingredients-{{ section.id }}">
  <div class="page-width">
    <div class="ds-ingredients__header">
      <span class="ds-ingredients__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="ds-ingredients__heading">{{ section.settings.heading }}</h2>
      <p class="ds-ingredients__subtext">{{ section.settings.subtext }}</p>
    </div>

    <div class="ds-ingredients__track-wrap">
      <div class="ds-ingredients__track" id="ds-ing-track-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'ingredient' %}
            <button
              class="ds-ing-card"
              data-modal="ds-ing-modal-{{ section.id }}-{{ forloop.index }}"
              {{ block.shopify_attributes }}
              aria-label="Learn more about {{ block.settings.name }}"
            >
              <div class="ds-ing-card__icon" style="--color: {{ block.settings.color }};">
                {% if block.settings.icon_svg != blank %}
                  {{ block.settings.icon_svg }}
                {% else %}
                  <span class="ds-ing-card__initial">{{ block.settings.name | slice: 0, 1 }}</span>
                {% endif %}
              </div>
              <div class="ds-ing-card__body">
                <p class="ds-ing-card__dose">{{ block.settings.dose }}</p>
                <h3 class="ds-ing-card__name">{{ block.settings.name }}</h3>
                <p class="ds-ing-card__benefit">{{ block.settings.benefit }}</p>
              </div>
              <span class="ds-ing-card__learn">Learn more →</span>
            </button>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ds-ingredients__nav">
      <button class="ds-ing-nav-btn" id="ds-ing-prev-{{ section.id }}" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="ds-ing-nav-btn" id="ds-ing-next-{{ section.id }}" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- Modals -->
{% for block in section.blocks %}
  {% if block.type == 'ingredient' %}
    <div
      class="ds-ing-modal"
      id="ds-ing-modal-{{ section.id }}-{{ forloop.index }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ block.settings.name }}"
      hidden
    >
      <div class="ds-ing-modal__overlay" data-close-modal></div>
      <div class="ds-ing-modal__panel">
        <button class="ds-ing-modal__close" data-close-modal aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>
        </button>
        <div class="ds-ing-modal__icon" style="--color: {{ block.settings.color }};">
          {% if block.settings.icon_svg != blank %}
            {{ block.settings.icon_svg }}
          {% else %}
            <span class="ds-ing-card__initial">{{ block.settings.name | slice: 0, 1 }}</span>
          {% endif %}
        </div>
        <p class="ds-ing-modal__dose">{{ block.settings.dose }}</p>
        <h2 class="ds-ing-modal__name">{{ block.settings.name }}</h2>
        <p class="ds-ing-modal__benefit">{{ block.settings.benefit }}</p>
        <div class="ds-ing-modal__divider"></div>
        <p class="ds-ing-modal__detail">{{ block.settings.detail }}</p>
        {% if block.settings.source != blank %}
          <p class="ds-ing-modal__source">Source: {{ block.settings.source }}</p>
        {% endif %}
      </div>
    </div>
  {% endif %}
{% endfor %}

<style>
  .ds-ingredients {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .ds-ingredients__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .ds-ingredients__eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 1rem;
  }

  .ds-ingredients__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.75rem;
  }

  .ds-ingredients__subtext {
    font-size: 1rem;
    color: {{ section.settings.body_color }};
    margin: 0;
  }

  .ds-ingredients__track-wrap {
    overflow: hidden;
  }

  .ds-ingredients__track {
    display: flex;
    gap: 1rem;
    transition: transform 0.4s ease;
    will-change: transform;
  }

  /* Ingredient Card */
  .ds-ing-card {
    flex: 0 0 calc(25% - 0.75rem);
    min-width: 220px;
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s, transform 0.2s;
    appearance: none;
  }

  .ds-ing-card:hover {
    border-color: {{ section.settings.heading_color }};
    transform: translateY(-2px);
  }

  .ds-ing-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--color, #888) 15%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color, #888);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .ds-ing-card__initial {
    font-size: 1.25rem;
    font-weight: 800;
  }

  .ds-ing-card__dose {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color, {{ section.settings.accent_color }});
    margin: 0;
  }

  .ds-ing-card__name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0.2rem 0 0.4rem;
  }

  .ds-ing-card__benefit {
    font-size: 0.8125rem;
    color: {{ section.settings.body_color }};
    margin: 0;
    line-height: 1.5;
    flex: 1;
  }

  .ds-ing-card__learn {
    font-size: 0.8125rem;
    font-weight: 600;
    color: {{ section.settings.body_color }};
    transition: color 0.2s;
  }

  .ds-ing-card:hover .ds-ing-card__learn {
    color: {{ section.settings.heading_color }};
  }

  /* Nav */
  .ds-ingredients__nav {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .ds-ing-nav-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid {{ section.settings.card_border }};
    background: transparent;
    color: {{ section.settings.heading_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .ds-ing-nav-btn:hover {
    background: {{ section.settings.heading_color }};
    border-color: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
  }

  /* Modal */
  .ds-ing-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .ds-ing-modal[hidden] {
    display: none;
  }

  .ds-ing-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .ds-ing-modal__panel {
    position: relative;
    background: {{ section.settings.background_color }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 24px 24px 0 0;
    padding: 2.5rem 2rem 3rem;
    width: 100%;
    max-width: 480px;
    animation: ds-modal-slide-up 0.35s ease;
  }

  .ds-ing-modal__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: {{ section.settings.card_background }};
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: {{ section.settings.heading_color }};
  }

  .ds-ing-modal__icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--color, #888) 15%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color, #888);
    margin-bottom: 1rem;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .ds-ing-modal__dose {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color, {{ section.settings.accent_color }});
    margin: 0 0 0.35rem;
  }

  .ds-ing-modal__name {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.5rem;
  }

  .ds-ing-modal__benefit {
    font-size: 0.9375rem;
    font-weight: 600;
    color: {{ section.settings.body_color }};
    margin: 0;
  }

  .ds-ing-modal__divider {
    height: 1px;
    background: {{ section.settings.card_border }};
    margin: 1.5rem 0;
  }

  .ds-ing-modal__detail {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: {{ section.settings.body_color }};
    margin: 0;
  }

  .ds-ing-modal__source {
    font-size: 0.75rem;
    color: {{ section.settings.body_color }};
    margin: 1.25rem 0 0;
    opacity: 0.6;
  }

  @keyframes ds-modal-slide-up {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (min-width: 768px) {
    .ds-ing-modal {
      align-items: center;
    }
    .ds-ing-modal__panel {
      border-radius: 24px;
    }
  }

  @media (max-width: 900px) {
    .ds-ing-card {
      flex: 0 0 calc(50% - 0.5rem);
    }
  }

  @media (max-width: 500px) {
    .ds-ing-card {
      flex: 0 0 80vw;
    }
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var track = document.getElementById('ds-ing-track-' + sectionId);
    var prevBtn = document.getElementById('ds-ing-prev-' + sectionId);
    var nextBtn = document.getElementById('ds-ing-next-' + sectionId);
    if (!track) return;

    var current = 0;
    var cardWidth = track.querySelector('.ds-ing-card').offsetWidth + 16;
    var visibleCount = Math.floor(track.parentElement.offsetWidth / cardWidth);
    var total = track.querySelectorAll('.ds-ing-card').length;

    function slide() {
      track.style.transform = 'translateX(-' + (current * cardWidth) + 'px)';
    }

    nextBtn && nextBtn.addEventListener('click', function() {
      if (current < total - visibleCount) current++;
      else current = 0;
      slide();
    });

    prevBtn && prevBtn.addEventListener('click', function() {
      if (current > 0) current--;
      else current = total - visibleCount;
      slide();
    });

    // Modals
    var cards = track.querySelectorAll('.ds-ing-card');
    cards.forEach(function(card) {
      card.addEventListener('click', function() {
        var modalId = card.getAttribute('data-modal');
        var modal = document.getElementById(modalId);
        if (modal) {
          modal.removeAttribute('hidden');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    document.querySelectorAll('[data-close-modal]').forEach(function(el) {
      el.addEventListener('click', function() {
        var modal = el.closest('.ds-ing-modal');
        if (modal) {
          modal.setAttribute('hidden', '');
          document.body.style.overflow = '';
        }
      });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.ds-ing-modal:not([hidden])').forEach(function(m) {
          m.setAttribute('hidden', '');
          document.body.style.overflow = '';
        });
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Ingredients",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Formula" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "8 Ingredients. One Goal." },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Every ingredient is clinically dosed and chosen for a specific reason. Tap any card to learn more." },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#f7f7f5" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#e5e5e5" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#0a0a0a" },
    { "type": "color", "id": "body_color", "label": "Body text", "default": "#888888" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#0a0a0a" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 80 }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Lion's Mane" },
        { "type": "text", "id": "dose", "label": "Dose", "default": "2,500 mg" },
        { "type": "text", "id": "benefit", "label": "Short benefit", "default": "Supports memory, focus, and nerve growth factor." },
        { "type": "textarea", "id": "detail", "label": "Full detail (modal)", "default": "Lion's Mane mushroom (Hericium erinaceus) stimulates Nerve Growth Factor (NGF), supporting long-term cognitive function, memory consolidation, and mental clarity. At 2,500mg, DayShift uses one of the highest doses available in any daily supplement." },
        { "type": "text", "id": "source", "label": "Source / study (optional)", "default": "" },
        { "type": "color", "id": "color", "label": "Accent color", "default": "#f59e0b" },
        { "type": "html", "id": "icon_svg", "label": "Icon SVG (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredients",
      "blocks": [
        { "type": "ingredient", "settings": { "name": "Lion's Mane", "dose": "2,500 mg", "benefit": "Supports memory, focus, and nerve growth factor.", "detail": "Lion's Mane mushroom (Hericium erinaceus) stimulates Nerve Growth Factor (NGF), supporting long-term cognitive function, memory consolidation, and mental clarity. At 2,500mg, DayShift uses one of the highest doses available in any daily supplement.", "color": "#f59e0b" } },
        { "type": "ingredient", "settings": { "name": "Cordyceps", "dose": "1,500 mg", "benefit": "Boosts ATP energy production and physical stamina.", "detail": "Cordyceps militaris increases ATP synthesis — the cellular fuel your body runs on. The result is a smoother, more sustained energy that complements caffeine without the spike-and-crash cycle.", "color": "#ef4444" } },
        { "type": "ingredient", "settings": { "name": "Alpha-GPC", "dose": "300 mg", "benefit": "Elevates acetylcholine for sharper focus and recall.", "detail": "Alpha-GPC is the most bioavailable form of choline available. It rapidly crosses the blood-brain barrier to raise acetylcholine levels — the neurotransmitter most responsible for attention, learning speed, and working memory.", "color": "#3b82f6" } },
        { "type": "ingredient", "settings": { "name": "Rhodiola Extract", "dose": "250 mg", "benefit": "Reduces mental fatigue and stress-induced burnout.", "detail": "Rhodiola rosea is an adaptogen with decades of research behind it. It directly reduces cortisol's impact on the brain, helping you stay sharp under pressure without the anxious edge that caffeine alone can create.", "color": "#8b5cf6" } },
