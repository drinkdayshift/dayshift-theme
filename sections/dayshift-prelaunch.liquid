{% comment %}
  DayShift — Prelaunch Section
  Top-weighted signup + product photo anchored at the bottom. Aeonik. SVG wordmark.
{% endcomment %}

<style>
  @font-face { font-family: "Aeonik"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-regular.woff2?v=1776969422") format("woff2"); font-weight: 400; font-style: normal; font-display: swap; }
  @font-face { font-family: "Aeonik"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-medium.woff2?v=1776969422") format("woff2"); font-weight: 500; font-style: normal; font-display: swap; }
  @font-face { font-family: "Aeonik"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-bold.woff2?v=1776969422") format("woff2"); font-weight: 700; font-style: normal; font-display: swap; }

  .shopify-section-header, #shopify-section-header, header.header, .header-wrapper,
  .announcement-bar, #shopify-section-announcement-bar,
  .shopify-section-group-header-group, .shopify-section-group-footer-group,
  footer.footer, #shopify-section-footer { display: none !important; }

  body { margin: 0; padding: 0; background: #0a0a0a; }

  .ds-pl {
    position: relative;
    min-height: 100vh;
    background: #0a0a0a;
    overflow: hidden;
    display: flex; flex-direction: column; align-items: center;
    padding: clamp(48px, 9vh, 104px) 24px 0;
    font-family: 'Aeonik', -apple-system, BlinkMacSystemFont, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-align: center;
  }

  .ds-pl__content { width: 100%; max-width: 480px; }
  .ds-pl__drip { width: clamp(150px, 34vw, 250px); margin: 0 auto -8px; }
  .ds-pl__drip img { width: 100%; height: auto; display: block; }
  .ds-pl__logo { width: clamp(260px, 60vw, 440px); margin: 0 auto 22px; }
  .ds-pl__logo svg { width: 100%; height: auto; display: block; }

  .ds-pl__hook {
    font-family: 'Aeonik', sans-serif;
    font-size: 18px; font-weight: 400; color: #e2e2e2;
    line-height: 1.5; max-width: 440px; margin: 0 auto 44px;
  }

  .ds-pl__coming-soon {
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: #777; margin-bottom: 10px;
  }
  .ds-pl__signup-text {
    font-size: 15px; font-weight: 400; color: #b4b4b4;
    margin: 0 auto 24px; line-height: 1.6; max-width: 400px;
  }
  .ds-pl__form-wrap { width: 100%; max-width: 400px; margin: 0 auto; }
  .ds-pl__form { display: flex; gap: 0; width: 100%; }
  .ds-pl__input {
    flex: 1; background: rgba(255,255,255,0.03);
    border: 1px solid #3a3a3a; border-right: none;
    border-radius: 6px 0 0 6px; padding: 14px 18px;
    font-family: 'Aeonik', sans-serif; font-size: 14px;
    color: #fff; outline: none; transition: border-color 0.2s;
    -webkit-appearance: none; min-width: 0;
  }
  .ds-pl__input::placeholder { color: #5a5a5a; }
  .ds-pl__input:focus { border-color: #777; }
  .ds-pl__submit {
    background: #ffffff; color: #0a0a0a;
    border: 1px solid #ffffff; border-radius: 0 6px 6px 0;
    padding: 14px 26px; font-family: 'Aeonik', sans-serif;
    font-size: 14px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.04em;
    cursor: pointer; white-space: nowrap; flex-shrink: 0;
    transition: background 0.15s;
  }
  .ds-pl__submit:hover { background: #e6e6e6; }

  .ds-pl__domain {
    margin-top: 16px; font-size: 12px; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase; color: #8a8a8a;
  }

  .ds-pl__success {
    display: none; align-items: center; justify-content: center;
    gap: 8px; color: #d2d2d2; font-size: 15px; line-height: 1.5;
  }
  .ds-pl__success svg { color: #4ade80; flex-shrink: 0; }

  .ds-pl__legal {
    font-size: 9.5px; line-height: 1.5; color: #3d3d3d;
    letter-spacing: 0.02em; max-width: 460px; margin: 18px auto 0;
  }

  .ds-pl__photo {
    margin-top: auto; width: 100%; position: relative;
    max-height: 55vh; overflow: hidden;
  }
  .ds-pl__photo img {
    width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block;
  }

  @media (max-width: 500px) {
    .ds-pl { padding: 40px 20px 0; }
    .ds-pl__form { flex-direction: column; }
    .ds-pl__input { border-right: 1px solid #3a3a3a; border-radius: 6px; margin-bottom: 8px; }
    .ds-pl__submit { border-radius: 6px; }
        .ds-pl__photo { max-width: 300px; }
        .ds-pl__drip { width: 66vw; }
  }
</style>

<div class="ds-pl">

  <div class="ds-pl__content">
        {% if section.settings.top_image != blank %}
      <div class="ds-pl__drip">{{ section.settings.top_image | image_url: width: 700 | image_tag: loading: 'eager', alt: '' }}</div>
    {% endif %}
    <div class="ds-pl__logo">
