ffffff" d="M 443.390625 17.660156 L 469.605469 17.660156 L 469.605469 24.976562 L 451.902344 24.976562 L 451.902344 34.273438 L 466.429688 34.273438 L 466.429688 41.242188 L 451.902344 41.242188 L 451.902344 57.339844 L 443.390625 57.339844 Z M 443.390625 17.660156 " fill-opacity="1" fill-rule="nonzero"/><path fill="#ffffff" d="M 452.054688 57.488281 L 443.234375 57.488281 L 443.234375 17.511719 L 469.753906 17.511719 L 469.753906 25.125 L 452.054688 25.125 L 452.054688 34.113281 L 466.582031 34.113281 L 466.582031 41.394531 L 452.054688 41.394531 Z M 443.542969 57.179688 L 451.746094 57.179688 L 451.746094 41.085938 L 466.273438 41.085938 L 466.273438 34.421875 L 451.746094 34.421875 L 451.746094 24.816406 L 469.445312 24.816406 L 469.445312 17.8125 L 443.542969 17.8125 Z M 443.542969 57.179688 " fill-opacity="1" fill-rule="nonzero"/><path fill="#ffffff" d="M 472.441406 17.660156 L 503.933594 17.660156 L 503.933594 24.976562 L 492.414062 24.976562 L 492.414062 57.339844 L 483.90625 57.339844 L 483.90625 24.976562 L 472.441406 24.976562 Z M 472.441406 17.660156 " fill-opacity="1" fill-rule="nonzero"/><path fill="#ffffff" d="M 492.566406 57.488281 L 483.746094 57.488281 L 483.746094 25.125 L 472.28125 25.125 L 472.28125 17.511719 L 504.085938 17.511719 L 504.085938 25.125 L 492.566406 25.125 Z M 484.054688 57.179688 L 492.257812 57.179688 L 492.257812 24.816406 L 503.777344 24.816406 L 503.777344 17.8125 L 472.59375 17.8125 L 472.59375 24.816406 L 484.054688 24.816406 Z M 484.054688 57.179688 " fill-opacity="1" fill-rule="nonzero"/><g transform="matrix(1, 0, 0, 1, 508, 16)"><g clip-path="url(#6867f4378b)"><g clip-path="url(#bdebc03ae3)"><g fill="#ffffff" fill-opacity="1"><g transform="translate(0.78638, 5.310333)"><g><path d="M 1.125 0 L 1.125 -2.859375 L 0.109375 -2.859375 L 0.109375 -3.5 L 2.890625 -3.5 L 2.890625 -2.859375 L 1.875 -2.859375 L 1.875 0 Z M 1.125 0 "/></g></g></g></g><g fill="#ffffff" fill-opacity="1"><g transform="translate(3.786405, 5.310333)"><g><