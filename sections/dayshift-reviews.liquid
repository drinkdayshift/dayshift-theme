{% comment %} DayShift — Reviews Carousel {% endcomment %}

<section class="ds-reviews" id="ds-reviews-{{ section.id }}">
  <div class="page-width">
    <div class="ds-reviews__header">
      <span class="ds-reviews__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="ds-reviews__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="ds-reviews__carousel-wrap">
      <div class="ds-reviews__track" id="ds-rev-track-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <div class="ds-review-card" {{ block.shopify_attributes }}>
              <div class="ds-review-card__stars">
                {% for i in (1..5) %}
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="{{ section.settings.star_color }}" xmlns="http://www.w3.org/2000/svg"><path d="M7 1l1.545 3.09L12 4.635l-2.5 2.455.59 3.41L7 8.91l-3.09 1.59.59-3.41L2 4.635l3.455-.545L7 1z"/></svg>
                {% endfor %}
              </div>
              <p class="ds-review-card__text">"{{ block.settings.review_text }}"</p>
              <div class="ds-review-card__author">
                <span class="ds-review-card__name">{{ block.settings.author_name }}</span>
                {% if block.settings.author_title != blank %}
                  <span class="ds-review-card__title">{{ block.settings.author_title }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ds-reviews__dots" id="ds-rev-dots-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <button class="ds-reviews__dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Review {{ forloop.index }}"></button>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ds-reviews {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .ds-reviews__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .ds-reviews__eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 1rem;
  }

  .ds-reviews__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: {{ section.settings.heading_color }};
    margin: 0;
  }

  .ds-reviews__carousel-wrap {
    overflow: hidden;
  }

  .ds-reviews__track {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.5s ease;
  }

  .ds-review-card {
    flex: 0 0 calc(33.333% - 0.84rem);
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ds-review-card__stars {
    display: flex;
    gap: 2px;
  }

  .ds-review-card__text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: {{ section.settings.heading_color }};
    margin: 0;
    flex: 1;
  }

  .ds-review-card__author {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-top: 1rem;
    border-top: 1px solid {{ section.settings.card_border }};
  }

  .ds-review-card__name {
    font-size: 0.875rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
  }

  .ds-review-card__title {
    font-size: 0.75rem;
    color: {{ section.settings.body_color }};
  }

  .ds-reviews__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .ds-reviews__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: {{ section.settings.card_border }};
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    padding: 0;
  }

  .ds-reviews__dot.active {
    background: {{ section.settings.heading_color }};
    transform: scale(1.3);
  }

  @media (max-width: 900px) {
    .ds-review-card {
      flex: 0 0 calc(50% - 0.625rem);
    }
  }

  @media (max-width: 560px) {
    .ds-review-card {
      flex: 0 0 85vw;
    }
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var track = document.getElementById('ds-rev-track-' + sectionId);
    var dotsWrap = document.getElementById('ds-rev-dots-' + sectionId);
    if (!track) return;

    var cards = track.querySelectorAll('.ds-review-card');
    var dots = dotsWrap ? dotsWrap.querySelectorAll('.ds-reviews__dot') : [];
    var current = 0;
    var autoplayInterval;
    var cardWidth = cards[0] ? cards[0].offsetWidth + 20 : 0;

    function goTo(index) {
      current = index;
      track.style.transform = 'translateX(-' + (current * cardWidth) + 'px)';
      dots.forEach(function(d, i) {
        d.classList.toggle('active', i === current);
      });
    }

    function startAutoplay() {
      autoplayInterval = setInterval(function() {
        goTo((current + 1) % cards.length);
      }, {{ section.settings.autoplay_speed }}000);
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        clearInterval(autoplayInterval);
        goTo(parseInt(dot.getAttribute('data-index')));
        startAutoplay();
      });
    });

    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real Results" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What People Are Saying" },
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay speed (seconds)", "min": 3, "max": 10, "step": 1, "default": 5 },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#0a0a0a" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#141414" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#222222" },
    { "type": "color", "id": "heading_color", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "body_color", "label": "Secondary text", "default": "#888888" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#ffffff" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#f59e0b" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 96 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "review_text", "label": "Review", "default": "I've tried every nootropic on the market. DayShift is the first one where I feel a noticeable difference every single time." },
        { "type": "text", "id": "author_name", "label": "Name", "default": "Alex R." },
        { "type": "text", "id": "author_title", "label": "Title / context", "default": "Founder, 3x startup" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "review_text": "I've tried every nootropic on the market. DayShift is the first one where I feel a noticeable difference every single time.", "author_name": "Alex R.", "author_title": "Founder, 3x startup" } },
        { "type": "review", "settings": { "review_text": "No crash at 3pm for the first time in years. I thought I was just wired that way. Turns out I was just under-fueled.", "author_name": "Morgan T.", "author_title": "Senior PM, tech company" } },
        { "type": "review", "settings": { "review_text": "The citrus yuzu flavor actually tastes good. That was the first surprise. The focus was the second.", "author_name": "Jamie L.", "author_title": "Designer" } },
        { "type": "review", "settings": { "review_text": "I replaced my afternoon coffee with DayShift. Sleeping better, working sharper. I'm not going back.", "author_name": "Sam K.", "author_title": "Attorney" } },
        { "type": "review", "settings": { "review_text": "Week two is when it clicks. Day one is good. Week two is when you realize this is a different gear entirely.", "author_name": "Chris D.", "author_title": "Operations lead" } }
      ]
    }
  ]
}
{% endschema %}
