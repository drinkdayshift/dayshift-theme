{% comment %} DayShift — Reviews Carousel v2 {% endcomment %}

<section class="ds-reviews" id="ds-reviews-{{ section.id }}">
  <div class="page-width">
    <div class="ds-reviews__header">
      {% if section.settings.eyebrow != blank %}
        <span class="ds-reviews__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="ds-reviews__heading">{{ section.settings.heading }}</h2>
      <div class="ds-reviews__aggregate">
        <div class="ds-reviews__stars-agg">
          {% for i in (1..5) %}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.6 3.2 3.6.5-2.6 2.5.6 3.5L8 9.5l-3.2 1.7.6-3.5-2.6-2.5 3.6-.5L8 1.5z"/></svg>
          {% endfor %}
        </div>
        <span class="ds-reviews__aggregate-text">{{ section.settings.aggregate_text }}</span>
      </div>
    </div>

    <div class="ds-reviews__track-wrap">
      <div class="ds-reviews__track" id="ds-reviews-track-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <div class="ds-review-card" {{ block.shopify_attributes }}>
              <div class="ds-review-card__stars">
                {% for i in (1..5) %}
                  <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5l1.6 3.2 3.6.5-2.6 2.5.6 3.5L8 9.5l-3.2 1.7.6-3.5-2.6-2.5 3.6-.5L8 1.5z"/></svg>
                {% endfor %}
              </div>
              <p class="ds-review-card__text">"{{ block.settings.review_text }}"</p>
              <div class="ds-review-card__author">
                <span class="ds-review-card__name">{{ block.settings.author_name }}</span>
                {% if block.settings.author_title != blank %}
                  <span class="ds-review-card__role">{{ block.settings.author_title }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ds-reviews__nav">
      <button class="ds-reviews__nav-btn" id="ds-reviews-prev-{{ section.id }}" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="ds-reviews__dots" id="ds-reviews-dots-{{ section.id }}"></div>
      <button class="ds-reviews__nav-btn" id="ds-reviews-next-{{ section.id }}" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    {% if section.settings.cta_label != blank %}
      <div class="ds-reviews__cta">
        <a href="{{ section.settings.cta_url }}" class="ds-reviews__cta-btn">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .ds-reviews {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .ds-reviews__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .ds-reviews__eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 0.875rem;
    opacity: 0.6;
  }

  .ds-reviews__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1rem;
  }

  .ds-reviews__aggregate {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ds-reviews__stars-agg {
    display: flex;
    gap: 2px;
    color: {{ section.settings.star_color }};
  }

  .ds-reviews__aggregate-text {
    font-size: 0.875rem;
    color: {{ section.settings.body_color }};
    font-weight: 500;
  }

  .ds-reviews__track-wrap { overflow: hidden; }

  .ds-reviews__track {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .ds-review-card {
    flex: 0 0 calc(33.333% - 0.834rem);
    min-width: 280px;
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ds-review-card__stars {
    display: flex;
    gap: 2px;
    color: {{ section.settings.star_color }};
  }

  .ds-review-card__text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: {{ section.settings.heading_color }};
    margin: 0;
    flex: 1;
    font-style: italic;
  }

  .ds-review-card__author {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-top: 1rem;
    border-top: 1px solid {{ section.settings.card_border }};
  }

  .ds-review-card__name {
    font-size: 0.875rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
  }

  .ds-review-card__role {
    font-size: 0.75rem;
    color: {{ section.settings.body_color }};
  }

  .ds-reviews__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .ds-reviews__nav-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid {{ section.settings.card_border }};
    background: transparent;
    color: {{ section.settings.heading_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
  }

  .ds-reviews__nav-btn:hover { background: {{ section.settings.card_border }}; }

  .ds-reviews__dots {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .ds-reviews__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: {{ section.settings.card_border }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .ds-reviews__dot.is-active {
    background: {{ section.settings.heading_color }};
    transform: scale(1.4);
  }

  .ds-reviews__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  .ds-reviews__cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2.25rem;
    border-radius: 100px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
    transition: opacity 0.2s;
  }

  .ds-reviews__cta-btn:hover { opacity: 0.85; }

  @media (max-width: 900px) { .ds-review-card { flex: 0 0 calc(50% - 0.625rem); } }
  @media (max-width: 560px) { .ds-review-card { flex: 0 0 85vw; } }
</style>

<script>
(function() {
  var id = '{{ section.id }}';
  var track = document.getElementById('ds-reviews-track-' + id);
  var dotsWrap = document.getElementById('ds-reviews-dots-' + id);
  var prevBtn = document.getElementById('ds-reviews-prev-' + id);
  var nextBtn = document.getElementById('ds-reviews-next-' + id);
  if (!track) return;
  var cards = track.querySelectorAll('.ds-review-card');
  var total = cards.length;
  var current = 0;
  var timer;

  function vis() { return Math.max(1, Math.floor(track.parentElement.offsetWidth / (cards[0].offsetWidth + 20))); }
  function max() { return Math.max(0, total - vis()); }
  function cw() { return cards[0].offsetWidth + 20; }

  function buildDots() {
    dotsWrap.innerHTML = '';
    for (var i = 0; i <= max(); i++) {
      var d = document.createElement('button');
      d.className = 'ds-reviews__dot' + (i === 0 ? ' is-active' : '');
      d.setAttribute('data-i', i);
      d.addEventListener('click', function() { go(+this.getAttribute('data-i')); restart(); });
      dotsWrap.appendChild(d);
    }
  }

  function go(i) {
    current = Math.max(0, Math.min(i, max()));
    track.style.transform = 'translateX(-' + (current * cw()) + 'px)';
    dotsWrap.querySelectorAll('.ds-reviews__dot').forEach(function(d, j) { d.classList.toggle('is-active', j === current); });
  }

  function restart() {
    clearInterval(timer);
    timer = setInterval(function() { go(current >= max() ? 0 : current + 1); }, {{ section.settings.autoplay_speed | times: 1000 }});
  }

  nextBtn && nextBtn.addEventListener('click', function() { go(current >= max() ? 0 : current + 1); restart(); });
  prevBtn && prevBtn.addEventListener('click', function() { go(current <= 0 ? max() : current - 1); restart(); });
  buildDots(); restart();
  window.addEventListener('resize', function() { buildDots(); go(Math.min(current, max())); });
})();
</script>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real Results" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What People Are Saying" },
    { "type": "text", "id": "aggregate_text", "label": "Aggregate text", "default": "4.9 out of 5 — 500+ reviews" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Try DayShift Today" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay speed (sec)", "min": 3, "max": 10, "step": 1, "default": 5 },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#0a0a0a" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#141414" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#222222" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "body_color", "label": "Body color", "default": "#888888" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#ffffff" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#f59e0b" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 96 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "review_text", "label": "Review text", "default": "This stuff actually works." },
        { "type": "text", "id": "author_name", "label": "Name", "default": "Alex R." },
        { "type": "text", "id": "author_title", "label": "Role / title" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review", "settings": { "review_text": "I've tried every nootropic on the market. DayShift is the first one where I feel a noticeable difference every single time.", "author_name": "Alex R.", "author_title": "Founder, 3x startup" } },
        { "type": "review", "settings": { "review_text": "No crash at 3pm for the first time in years. I thought I was just wired that way. Turns out I was just under-fueled.", "author_name": "Morgan T.", "author_title": "Senior PM, tech company" } },
        { "type": "review", "settings": { "review_text": "The citrus yuzu flavor actually tastes good. That was the first surprise. The focus was the second.", "author_name": "Jamie L.", "author_title": "Designer" } },
        { "type": "review", "settings": { "review_text": "I replaced my afternoon coffee with DayShift. Sleeping better, working sharper. I'm not going back.", "author_name": "Sam K.", "author_title": "Attorney" } },
        { "type": "review", "settings": { "review_text": "Week two is when it clicks. Day one is good. Week two is when you realize this is a different gear entirely.", "author_name": "Chris D.", "author_title": "Operations lead" } }
      ]
    }
  ]
}
{% endschema %}