{% comment %} DayShift — Shop Grid v2 {% endcomment %}

<section class="ds-grid" id="ds-grid-{{ section.id }}">
  <div class="page-width">
    <div class="ds-grid__header">
      <h2 class="ds-grid__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subtext != blank %}
        <p class="ds-grid__subtext">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="ds-grid__cards">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' %}
          <div class="ds-grid__card" {{ block.shopify_attributes }} style="--accent: {{ block.settings.accent_color }};">
            {% if block.settings.badge != blank %}
              <div class="ds-grid__badge">{{ block.settings.badge }}</div>
            {% endif %}
            <div class="ds-grid__card-image">
              {% if block.settings.product_image != blank %}
                {{ block.settings.product_image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  alt: block.settings.product_name,
                  class: 'ds-grid__img'
                }}
              {% else %}
                <div class="ds-grid__img-placeholder">
                  <span>{{ block.settings.flavor_label }}</span>
                </div>
              {% endif %}
            </div>
            <div class="ds-grid__card-body">
              <div class="ds-grid__card-top">
                <h3 class="ds-grid__name">{{ block.settings.product_name }}</h3>
                <p class="ds-grid__desc">{{ block.settings.description }}</p>
              </div>
              <div class="ds-grid__card-bottom">
                <div class="ds-grid__pricing">
                  <span class="ds-grid__price">{{ block.settings.price }}</span>
                  {% if block.settings.subscribe_price != blank %}
                    <span class="ds-grid__sub-price">{{ block.settings.subscribe_price }} with sub</span>
                  {% endif %}
                </div>
                {% if block.settings.cta_url != blank %}
                  <a href="{{ block.settings.cta_url }}" class="ds-grid__cta">Shop Now</a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.cta_label != blank %}
      <div class="ds-grid__footer">
        <a href="{{ section.settings.cta_url }}" class="ds-grid__footer-cta">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .ds-grid {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .ds-grid__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .ds-grid__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.75rem;
  }

  .ds-grid__subtext {
    font-size: 0.9375rem;
    color: {{ section.settings.subtext_color }};
    margin: 0;
  }

  .ds-grid__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .ds-grid__card {
    background: {{ section.settings.card_background }};
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .ds-grid__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .ds-grid__badge {
    position: absolute;
    top: 0.875rem;
    left: 0.875rem;
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    z-index: 1;
  }

  .ds-grid__card-image {
    aspect-ratio: 1 / 1;
    background: color-mix(in srgb, var(--accent) 8%, {{ section.settings.card_background }});
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ds-grid__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ds-grid__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.5;
  }

  .ds-grid__card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .ds-grid__card-top {
    flex: 1;
  }

  .ds-grid__name {
    font-size: 1rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }

  .ds-grid__desc {
    font-size: 0.8125rem;
    color: {{ section.settings.subtext_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ds-grid__card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .ds-grid__pricing {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .ds-grid__price {
    font-size: 1rem;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.02em;
  }

  .ds-grid__sub-price {
    font-size: 0.6875rem;
    color: {{ section.settings.subtext_color }};
    font-weight: 500;
  }

  .ds-grid__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 700;
    text-decoration: none;
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
    white-space: nowrap;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .ds-grid__cta:hover { opacity: 0.8; }

  .ds-grid__footer {
    text-align: center;
    margin-top: 2.5rem;
  }

  .ds-grid__footer-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2.25rem;
    border-radius: 100px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    border: 1.5px solid {{ section.settings.heading_color }};
    color: {{ section.settings.heading_color }};
    transition: background 0.2s, color 0.2s;
  }

  .ds-grid__footer-cta:hover {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
  }

  @media (max-width: 900px) {
    .ds-grid__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .ds-grid__cards { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .ds-grid__card-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>

{% schema %}
{
  "name": "Shop Grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose Your Flavor" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "All flavors ship with 20 sachets per box — 5 days on, 2 days off." },
    { "type": "text", "id": "cta_label", "label": "Footer CTA label", "default": "View All Products" },
    { "type": "url", "id": "cta_url", "label": "Footer CTA link" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#f7f7f5" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#0a0a0a" },
    { "type": "color", "id": "subtext_color", "label": "Subtext color", "default": "#888888" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 80 }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "product_name", "label": "Product name", "default": "Citrus Yuzu" },
        { "type": "text", "id": "flavor_label", "label": "Flavor label", "default": "Orange" },
        { "type": "text", "id": "description", "label": "Description", "default": "Bright and citrusy. Morning energy, refined." },
        { "type": "text", "id": "price", "label": "Price", "default": "$49 / box" },
        { "type": "text", "id": "subscribe_price", "label": "Subscribe price" },
        { "type": "text", "id": "badge", "label": "Badge (optional)" },
        { "type": "url", "id": "cta_url", "label": "Shop link" },
        { "type": "image_picker", "id": "product_image", "label": "Product image" },
        { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#0a0a0a" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Grid",
      "blocks": [
        { "type": "product_card", "settings": { "product_name": "Variety Pack", "flavor_label": "All Flavors", "description": "Can't pick one? Get them all. Perfect for first-timers.", "price": "$54 / box", "subscribe_price": "$48", "badge": "Best Seller", "accent_color": "#0a0a0a" } },
        { "type": "product_card", "settings": { "product_name": "Watermelon Lime", "flavor_label": "Pink", "description": "Crisp and refreshing. The everyday go-to.", "price": "$49 / box", "subscribe_price": "$44", "accent_color": "#f87171" } },
        { "type": "product_card", "settings": { "product_name": "Citrus Yuzu", "flavor_label": "Orange", "description": "Bright and citrusy. Morning energy, refined.", "price": "$49 / box", "subscribe_price": "$44", "accent_color": "#fb923c" } },
        { "type": "product_card", "settings": { "product_name": "Mixed Berry", "flavor_label": "Purple", "description": "Bold and smooth. For the ones who mean business.", "price": "$49 / box", "subscribe_price": "$44", "accent_color": "#a855f7" } }
      ]
    }
  ]
}
{% endschema %}