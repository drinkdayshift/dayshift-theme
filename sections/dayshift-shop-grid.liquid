    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button text",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#f7f7f5"
    },
    {
      "type": "color",
