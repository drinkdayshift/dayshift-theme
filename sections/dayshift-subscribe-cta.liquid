{% comment %} DayShift — Subscribe CTA v2 {% endcomment %}

<section class="ds-sub" id="ds-sub-{{ section.id }}">
  <div class="page-width">
    <div class="ds-sub__header">
      {% if section.settings.eyebrow != blank %}
        <span class="ds-sub__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="ds-sub__heading">{{ section.settings.heading | newline_to_br }}</h2>
      <p class="ds-sub__body">{{ section.settings.body }}</p>
    </div>

    <div class="ds-sub__plans">
      <div class="ds-sub__plan ds-sub__plan--subscribe">
        <div class="ds-sub__plan-badge">Best Value</div>
        <div class="ds-sub__plan-top">
          <span class="ds-sub__plan-type">Subscribe</span>
          <div class="ds-sub__plan-price">
            <span class="ds-sub__plan-amount">{{ section.settings.subscribe_price }}</span>
            <span class="ds-sub__plan-period">/ box</span>
          </div>
          <p class="ds-sub__plan-note">{{ section.settings.subscribe_subtext }}</p>
        </div>
        <div class="ds-sub__plan-perks">
          {% for block in section.blocks %}
            {% if block.type == 'perk' %}
              <div class="ds-sub__perk" {{ block.shopify_attributes }}>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="8" fill="currentColor" opacity="0.15"/>
                  <path d="M5 8L7.2 10.5L11 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {{ block.settings.text }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
        {% if section.settings.cta_primary_label != blank %}
          <a href="{{ section.settings.cta_primary_url }}" class="ds-sub__cta-primary">{{ section.settings.cta_primary_label }}</a>
        {% endif %}
      </div>

      <div class="ds-sub__plan ds-sub__plan--onetime">
        <div class="ds-sub__plan-top">
          <span class="ds-sub__plan-type">One-Time</span>
          <div class="ds-sub__plan-price">
            <span class="ds-sub__plan-amount ds-sub__plan-amount--muted">{{ section.settings.one_time_price }}</span>
            <span class="ds-sub__plan-period">/ box</span>
          </div>
          <p class="ds-sub__plan-note">No commitment. Order once.</p>
        </div>
        {% if section.settings.cta_secondary_label != blank %}
          <a href="{{ section.settings.cta_secondary_url }}" class="ds-sub__cta-secondary">{{ section.settings.cta_secondary_label }}</a>
        {% endif %}
      </div>
    </div>

    {% if section.settings.guarantee != blank %}
      <p class="ds-sub__guarantee">{{ section.settings.guarantee }}</p>
    {% endif %}
  </div>
</section>

<style>
  .ds-sub {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .ds-sub__header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .ds-sub__eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 0.875rem;
    opacity: 0.6;
  }

  .ds-sub__heading {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .ds-sub__body {
    font-size: 1rem;
    color: {{ section.settings.body_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ds-sub__plans {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .ds-sub__plan {
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }

  .ds-sub__plan--subscribe {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
  }

  .ds-sub__plan--onetime {
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.card_border }};
    color: {{ section.settings.heading_color }};
  }

  .ds-sub__plan-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.background_color }};
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.875rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .ds-sub__plan-top {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .ds-sub__plan-type {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .ds-sub__plan-price {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .ds-sub__plan-amount {
    font-size: 2.25rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .ds-sub__plan-amount--muted { opacity: 0.7; }

  .ds-sub__plan-period {
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .ds-sub__plan-note {
    font-size: 0.8125rem;
    opacity: 0.6;
    margin: 0;
  }

  .ds-sub__plan-perks {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .ds-sub__perk {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .ds-sub__perk svg { flex-shrink: 0; }

  .ds-sub__cta-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.5rem;
    border-radius: 100px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    background: {{ section.settings.background_color }};
    color: {{ section.settings.heading_color }};
    transition: opacity 0.2s;
    text-align: center;
  }

  .ds-sub__cta-primary:hover { opacity: 0.85; }

  .ds-sub__cta-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.5rem;
    border-radius: 100px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    border: 1.5px solid {{ section.settings.card_border }};
    color: {{ section.settings.heading_color }};
    background: transparent;
    transition: background 0.2s, color 0.2s;
    text-align: center;
  }

  .ds-sub__cta-secondary:hover {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.background_color }};
    border-color: {{ section.settings.heading_color }};
  }

  .ds-sub__guarantee {
    text-align: center;
    font-size: 0.8125rem;
    color: {{ section.settings.body_color }};
    margin: 1.75rem 0 0;
  }

  @media (max-width: 600px) {
    .ds-sub__plans {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }
</style>

{% schema %}
{
  "name": "Subscribe CTA",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Subscribe & Save" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Never Run Out.\nNever Miss a Day." },
    { "type": "text", "id": "body", "label": "Body", "default": "Subscribe and get 20 sachets delivered every 4 weeks. Pause, skip, or cancel any time." },
    { "type": "text", "id": "cta_primary_label", "label": "Subscribe CTA", "default": "Subscribe & Save 10%" },
    { "type": "url", "id": "cta_primary_url", "label": "Subscribe link" },
    { "type": "text", "id": "cta_secondary_label", "label": "One-time CTA", "default": "Buy Once" },
    { "type": "url", "id": "cta_secondary_url", "label": "One-time link" },
    { "type": "text", "id": "subscribe_price", "label": "Subscribe price", "default": "$44" },
    { "type": "text", "id": "subscribe_subtext", "label": "Subscribe note", "default": "Save 10% vs one-time. Free shipping." },
    { "type": "text", "id": "one_time_price", "label": "One-time price", "default": "$49" },
    { "type": "text", "id": "guarantee", "label": "Guarantee text", "default": "✓ Free shipping  ·  ✓ Cancel any time  ·  ✓ Swap flavors each cycle" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#0a0a0a" },
    { "type": "color", "id": "card_background", "label": "One-time card bg", "default": "#141414" },
    { "type": "color", "id": "card_border", "label": "One-time card border", "default": "#2a2a2a" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "body_color", "label": "Body color", "default": "#888888" },
    { "type": "color", "id": "accent_color", "label": "Badge accent", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 96 }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Subscribe Perk",
      "settings": [
        { "type": "text", "id": "text", "label": "Perk text", "default": "Free shipping on every order" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Subscribe CTA",
      "blocks": [
        { "type": "perk", "settings": { "text": "Free shipping on every order" } },
        { "type": "perk", "settings": { "text": "Pause or cancel any time" } },
        { "type": "perk", "settings": { "text": "Swap flavors each cycle" } },
        { "type": "perk", "settings": { "text": "10% off vs one-time pricing" } }
      ]
    }
  ]
}
{% endschema %}
