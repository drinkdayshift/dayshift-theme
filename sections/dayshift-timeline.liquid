{% comment %} DayShift — Effects Timeline {% endcomment %}

<section class="ds-timeline" id="ds-timeline-{{ section.id }}">
  <div class="page-width">
    <div class="ds-timeline__header">
      <span class="ds-timeline__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="ds-timeline__heading">{{ section.settings.heading }}</h2>
      <p class="ds-timeline__subtext">{{ section.settings.subtext }}</p>
    </div>

    <div class="ds-timeline__track">
      <div class="ds-timeline__line"></div>
      {% for block in section.blocks %}
        {% if block.type == 'milestone' %}
          <div class="ds-timeline__item" {{ block.shopify_attributes }}>
            <div class="ds-timeline__dot"></div>
            <div class="ds-timeline__card">
              <span class="ds-timeline__time">{{ block.settings.time_label }}</span>
              <h3 class="ds-timeline__title">{{ block.settings.title }}</h3>
              <p class="ds-timeline__desc">{{ block.settings.description }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ds-timeline {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .ds-timeline__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .ds-timeline__eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 1rem;
  }

  .ds-timeline__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.75rem;
  }

  .ds-timeline__subtext {
    font-size: 1rem;
    color: {{ section.settings.body_color }};
    margin: 0;
  }

  .ds-timeline__track {
    display: flex;
    gap: 0;
    position: relative;
    overflow-x: auto;
    padding-bottom: 1rem;
    scrollbar-width: none;
  }

  .ds-timeline__track::-webkit-scrollbar {
    display: none;
  }

  .ds-timeline__line {
    position: absolute;
    top: 16px;
    left: 0;
    right: 0;
    height: 1px;
    background: {{ section.settings.line_color }};
    z-index: 0;
  }

  .ds-timeline__item {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    padding-top: 0;
  }

  .ds-timeline__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: {{ section.settings.accent_color }};
    border: 3px solid {{ section.settings.background_color }};
    outline: 1px solid {{ section.settings.accent_color }};
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    margin-bottom: 1.5rem;
  }

  .ds-timeline__card {
    padding: 0 1rem;
    text-align: center;
  }

  .ds-timeline__time {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    background: color-mix(in srgb, {{ section.settings.accent_color }} 10%, transparent);
    border-radius: 100px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 0.75rem;
  }

  .ds-timeline__title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.5rem;
  }

  .ds-timeline__desc {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: {{ section.settings.body_color }};
    margin: 0;
  }

  @media (max-width: 700px) {
    .ds-timeline__track {
      flex-direction: column;
      overflow-x: visible;
    }
    .ds-timeline__line {
      top: 0;
      left: 16px;
      bottom: 0;
      right: auto;
      width: 1px;
      height: auto;
    }
    .ds-timeline__item {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.25rem;
      padding: 0 0 2rem 0;
      min-width: auto;
    }
    .ds-timeline__dot {
      margin-bottom: 0;
      flex-shrink: 0;
      margin-top: 4px;
    }
    .ds-timeline__card {
      text-align: left;
      padding: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Effects Timeline",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What to Expect" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Feel the Difference Over Time" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Some effects are felt immediately. Others build the longer you stay consistent." },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#0a0a0a" },
    { "type": "color", "id": "body_color", "label": "Body text", "default": "#888888" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#0a0a0a" },
    { "type": "color", "id": "line_color", "label": "Timeline line", "default": "#e5e5e5" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 40, "max": 120, "step": 8, "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 40, "max": 120, "step": 8, "default": 96 }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        { "type": "text", "id": "time_label", "label": "Time label", "default": "Hour 1" },
        { "type": "text", "id": "title", "label": "Title", "default": "Clean Energy Onset" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Caffeine and Cordyceps kick in. Smooth, focused lift — no spike, no jitters." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Effects Timeline",
      "blocks": [
        { "type": "milestone", "settings": { "time_label": "Minutes 15–30", "title": "First Lift", "description": "Caffeine + L-Theanine activate. Clear, calm focus replaces mental fog." } },
        { "type": "milestone", "settings": { "time_label": "Hour 1–3", "title": "Peak Performance", "description": "Alpha-GPC and NALT fully active. Working memory, motivation, and output are at their highest." } },
        { "type": "milestone", "settings": { "time_label": "Hour 4–6", "title": "Sustained Clarity", "description": "No crash. Rhodiola keeps cortisol in check while the effects taper cleanly." } },
        { "type": "milestone", "settings": { "time_label": "Day 3", "title": "Noticeable Shift", "description": "Lion's Mane begins compounding. Mental stamina and recovery between sessions improves." } },
        { "type": "milestone", "settings": { "time_label": "Week 2+", "title": "Cognitive Edge", "description": "Consistent users report sharper recall, better stress response, and faster mental processing." } }
      ]
    }
  ]
}
{% endschema %}
