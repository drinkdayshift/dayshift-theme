<style>
@font-face { font-family: "Aeonik"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-regular.woff2") format("woff2"); font-weight: 400; font-style: normal; font-display: swap; }
@font-face { font-family: "Aeonik"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-italic.woff2") format("woff2"); font-weight: 400; font-style: italic; font-display: swap; }
@font-face { font-family: "Aeonik"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-medium.woff2") format("woff2"); font-weight: 500; font-style: normal; font-display: swap; }
@font-face { font-family: "Aeonik"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-bold.woff2") format("woff2"); font-weight: 700; font-style: normal; font-display: swap; }

html body .policies,
html body .policies * {
  font-family: "Aeonik", -apple-system, BlinkMacSystemFont, sans-serif !important;
  font-style: normal;
}

html body .policies {
  max-width: 880px !important;
  margin: 0 auto !important;
  padding: 80px 32px 96px !important;
  color: #1f1f1f !important;
  background: #fff !important;
}

html body .policies h1,
html body .policies h1.title {
  font-size: 64px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: -0.01em !important;
  line-height: 1.05 !important;
  text-align: center !important;
  color: #0A0A0A !important;
  margin: 0 0 56px 0 !important;
}

html body .policies .rte h2 {
  font-size: 32px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: -0.01em !important;
  line-height: 1.15 !important;
  margin: 64px 0 20px 0 !important;
  color: #0A0A0A !important;
}

html body .policies .rte h3 {
  font-size: 20px !important;
  font-weight: 700 !important;
  line-height: 1.3 !important;
  margin: 40px 0 14px 0 !important;
  color: #0A0A0A !important;
}

html body .policies .rte p {
  font-size: 16px !important;
  line-height: 1.7 !important;
  margin: 0 0 18px 0 !important;
  color: #1f1f1f !important;
}

html body .policies .rte ul,
html body .policies .rte ol {
  margin: 0 0 20px 0 !important;
  padding-left: 24px !important;
}

html body .policies .rte li {
  font-size: 16px !important;
  line-height: 1.7 !important;
  margin-bottom: 8px !important;
  color: #1f1f1f !important;
}

html body .policies .rte strong {
  font-weight: 700 !important;
  color: #0A0A0A !important;
}

html body .policies .rte em,
html body .policies .rte i {
  font-style: italic !important;
}

html body .policies .rte a {
  color: #6B2FE0 !important;
  text-decoration: underline;
  text-underline-offset: 2px;
}
html body .policies .rte a:hover {
  color: #4a1fa3 !important;
}

@media (max-width: 720px) {
  html body .policies { padding: 48px 22px 64px !important; }
  html body .policies h1 { font-size: 40px !important; margin-bottom: 36px !important; }
  html body .policies .rte h2 { font-size: 24px !important; margin-top: 48px !important; }
  html body .policies .rte h3 { font-size: 17px !important; }
  html body .policies .rte p,
  html body .policies .rte li { font-size: 15px !important; }
}
</style>

<div class="policies">
  <h1 class="title">{{ page.title | escape }}</h1>
  <div class="rte">{{ page.content }}</div>
</div>

{% schema %}
{
  "name": "Policies",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}