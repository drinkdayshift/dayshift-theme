    "faq": {
      "type": "dayshift-faq",
      "blocks": {
        "q1": { "type": "question", "settings": { "question": "How long until I feel effects?", "answer": "<p>Most people feel the initial lift within 15–30 minutes. The caffeine and L-Theanine activate quickly. Longer-term benefits from Lion's Mane and Cordyceps build over 1–2 weeks of consistent use.</p>" } },
        "q2": { "type": "question", "settings": { "question": "What is the 5-day protocol?", "answer": "<p>DayShift is designed to be taken Monday through Friday — your workdays. The 2-day rest period prevents tolerance buildup and lets your system reset, so each dose stays effective.</p>" } },
        "q3": { "type": "question", "settings": { "question": "Can I take it with coffee?", "answer": "<p>DayShift already contains 120mg of caffeine. You can combine it with coffee but be mindful of your total caffeine intake. We'd suggest skipping the extra coffee for the first week to assess your personal response.</p>" } },
        "q4": { "type": "question", "settings": { "question": "Is it safe to take every day?", "answer": "<p>Yes — within the 5-on/2-off protocol. All 8 ingredients have strong safety profiles at these doses. If you have a medical condition or take prescription medications, check with your doctor first.</p>" } },
        "q5": { "type": "question", "settings": { "question": "What does it taste like?", "answer": "<p>Each flavor is clean, refreshing, and not overly sweet. Watermelon Lime is crisp and bright. Citrus Yuzu is light and citrusy. Mixed Berry is smooth and full-bodied.</p>" } },
        "q6": { "type": "question", "settings": { "question": "How do I cancel my subscription?", "answer": "<p>Log in to your account and manage your subscription from the portal. You can pause, skip a cycle, swap flavors, or cancel entirely — no phone calls, no friction.</p>" } }
