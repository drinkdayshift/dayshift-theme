    "ingredients": {
      "type": "dayshift-ingredients",
      "blocks": {
        "ing_1": { "type": "ingredient", "settings": { "name": "Lion's Mane", "dose": "2,500 mg", "benefit": "Supports memory, focus, and nerve growth factor.", "detail": "Lion's Mane mushroom (Hericium erinaceus) stimulates Nerve Growth Factor (NGF), supporting long-term cognitive function, memory consolidation, and mental clarity. At 2,500mg, DayShift uses one of the highest doses available in any daily supplement.", "color": "#f59e0b" } },
        "ing_2": { "type": "ingredient", "settings": { "name": "Cordyceps", "dose": "1,500 mg", "benefit": "Boosts ATP energy production and physical stamina.", "detail": "Cordyceps militaris increases ATP synthesis — the cellular fuel your body runs on. The result is a smoother, more sustained energy that complements caffeine without the spike-and-crash cycle.", "color": "#ef4444" } },
        "ing_3": { "type": "ingredient", "settings": { "name": "Alpha-GPC", "dose": "300 mg", "benefit": "Elevates acetylcholine for sharper focus and recall.", "detail": "Alpha-GPC is the most bioavailable form of choline available. It rapidly crosses the blood-brain barrier to raise acetylcholine levels — the neurotransmitter most responsible for attention, learning speed, and working memory.", "color": "#3b82f6" } },
        "ing_4": { "type": "ingredient", "settings": { "name": "Rhodiola Extract", "dose": "250 mg", "benefit": "Reduces mental fatigue and stress-induced burnout.", "detail": "Rhodiola rosea is an adaptogen with decades of research behind it. It directly reduces cortisol's impact on the brain, helping you stay sharp under pressure without the anxious edge that caffeine alone can create.", "color": "#8b5cf6" } },
        "ing_5": { "type": "ingredient", "settings": { "name": "L-Theanine", "dose": "240 mg", "benefit": "Smooth focus without the jitter or anxiety.", "detail": "L-Theanine is the amino acid found in green tea that produces calm alertness. Paired with caffeine at a 2:1 ratio, it eliminates jitters and anxiety while amplifying the cognitive benefits of stimulation.", "color": "#10b981" } },
        "ing_6": { "type": "ingredient", "settings": { "name": "NALT", "dose": "600 mg", "benefit": "Precursor to dopamine and norepinephrine.", "detail": "N-Acetyl L-Tyrosine (NALT) is a highly bioavailable form of L-Tyrosine. It's the direct precursor to dopamine and norepinephrine — the brain chemicals that drive motivation, mood, and stress resilience.", "color": "#f97316" } },
        "ing_7": { "type": "ingredient", "settings": { "name": "Panax Ginseng", "dose": "200 mg", "benefit": "Enhances working memory and mental performance.", "detail": "Panax ginseng has been shown in multiple trials to improve reaction time, working memory, and cognitive performance under fatigue. It pairs with Lion's Mane to produce compounding long-term benefits.", "color": "#ec4899" } },
        "ing_8": { "type": "ingredient", "settings": { "name": "Caffeine", "dose": "120 mg", "benefit": "Clean, precisely dosed stimulation without the crash.", "detail": "120mg is the cognitive sweet spot — enough to sharpen alertness and block adenosine, but low enough to avoid the crash. Combined with L-Theanine, it becomes clean, sustained focus.", "color": "#6366f1" } }
