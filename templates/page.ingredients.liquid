{%- comment -%} DayShift Ingredients Index — self-contained template. Cards link to each ingredient page. {%- endcomment -%}

{%- comment -%}
  ============================================================
  PHOTOS
  ------------------------------------------------------------
  These pull from Content > Files by filename via file_url.
  If a filename below does not match exactly what is in Files,
  just fix the filename string. A missing file shows a clean
  gray block instead of a broken image.
  ============================================================
{%- endcomment -%}

{%- assign img_lions_mane   = "lions-mane-hero.png"     | file_url -%}
{%- assign img_alpha_gpc    = "alpha-gpc-hero.png"      | file_url -%}
{%- assign img_caffeine     = "caffeine-hero.png"       | file_url -%}
{%- assign img_l_theanine   = "l-theanine-hero.png"     | file_url -%}
{%- assign img_cordyceps    = "cordyceps-hero.png"      | file_url -%}
{%- assign img_nalt         = "nalt-hero.png"           | file_url -%}
{%- assign img_panax        = "panax-ginseng-hero.png"  | file_url -%}
{%- assign img_rhodiola     = "rhodiola-rosea-hero.png" | file_url -%}

{%- comment -%} === SEO META === {%- endcomment -%}
{%- assign seo_title = "Ingredients | What's Inside DayShift" -%}
{%- assign seo_desc = "Every active in DayShift, fully dosed and fully disclosed. Explore the eight nootropics and adaptogens that build a new baseline of cognitive performance." -%}
{%- assign seo_url = shop.url | append: '/pages/ingredients' -%}

<meta name="description" content="{{ seo_desc }}">
<link rel="canonical" href="{{ seo_url }}">
<meta name="robots" content="index, follow">

<meta property="og:type" content="website">
<meta property="og:title" content="{{ seo_title }}">
<meta property="og:description" content="{{ seo_desc }}">
<meta property="og:url" content="{{ seo_url }}">
<meta property="og:site_name" content="DayShift">

<style>
@font-face { font-family: "AeonikDS"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-regular.woff2") format("woff2"); font-weight: 400; font-style: normal; font-display: swap; }
@font-face { font-family: "AeonikDS"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-italic.woff2") format("woff2"); font-weight: 400; font-style: italic; font-display: swap; }
@font-face { font-family: "AeonikDS"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-medium.woff2") format("woff2"); font-weight: 500; font-style: normal; font-display: swap; }
@font-face { font-family: "AeonikDS"; src: url("https://cdn.shopify.com/s/files/1/0962/3676/5551/files/aeonik-bold.woff2") format("woff2"); font-weight: 700; font-style: normal; font-display: swap; }

html body .ds-ingredients-page,
html body .ds-ingredients-page * {
  font-family: "AeonikDS", -apple-system, BlinkMacSystemFont, sans-serif !important;
  box-sizing: border-box;
}

html body .ds-ingredients-page {
  width: 100%;
  background: #fff;
  color: #0A0A0A;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

html body .ds-ingredients-page .container {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ============ HERO ============ */

html body .ds-ingredients-page .hero {
  text-align: center;
  padding: 80px 0 40px;
}

html body .ds-ingredients-page h1.hero-title {
  font-size: 64px !important;
  font-weight: 700 !important;
  line-height: 1.02 !important;
  letter-spacing: -0.02em !important;
  text-transform: uppercase !important;
  margin: 0 auto 20px !important;
  color: #0A0A0A !important;
}

html body .ds-ingredients-page .hero-sub {
  font-size: 19px !important;
  line-height: 1.55 !important;
  color: #1f1f1f !important;
  max-width: 620px !important;
  margin: 0 auto !important;
}

@media (max-width: 720px) {
  html body .ds-ingredients-page .hero { padding: 56px 0 28px; }
  html body .ds-ingredients-page h1.hero-title { font-size: 42px !important; letter-spacing: -0.015em !important; }
  html body .ds-ingredients-page .hero-sub { font-size: 17px !important; }
}

/* ============ GRID ============ */

html body .ds-ingredients-page .ing-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  padding-bottom: 64px;
}

@media (max-width: 1100px) {
  html body .ds-ingredients-page .ing-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 820px) {
  html body .ds-ingredients-page .ing-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
}
@media (max-width: 480px) {
  html body .ds-ingredients-page .ing-grid { grid-template-columns: 1fr; }
}

html body .ds-ingredients-page .ing-card {
  display: flex;
  flex-direction: column;
  background: #fff !important;
  border: 1px solid #E5E5E5 !important;
  border-radius: 16px !important;
  overflow: hidden;
  text-decoration: none !important;
  color: #0A0A0A !important;
  transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
}

html body .ds-ingredients-page .ing-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 28px rgba(0,0,0,0.08);
  border-color: #D5D5D5 !important;
}

html body .ds-ingredients-page .ing-card-img {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #F4F4F4;
  overflow: hidden;
}

html body .ds-ingredients-page .ing-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

html body .ds-ingredients-page .ing-card-body {
  padding: 22px 22px 24px;
  flex: 1;
}

html body .ds-ingredients-page .ing-card-name {
  font-size: 21px !important;
  font-weight: 700 !important;
  line-height: 1.2 !important;
  letter-spacing: -0.01em !important;
  margin: 0 0 8px 0 !important;
  color: #0A0A0A !important;
  text-transform: none !important;
}

html body .ds-ingredients-page .ing-card:hover .ing-card-name {
  color: #FF8300 !important;
}

html body .ds-ingredients-page .ing-card-desc {
  font-size: 15px !important;
  line-height: 1.55 !important;
  color: #4A4A4A !important;
  margin: 0 0 14px 0 !important;
}

html body .ds-ingredients-page .ing-card-link {
  font-size: 14px !important;
  font-weight: 500 !important;
  color: #0A0A0A !important;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

html body .ds-ingredients-page .ing-card:hover .ing-card-link {
  color: #FF8300 !important;
}

html body .ds-ingredients-page .ing-card-link .arrow {
  transition: transform 200ms ease;
}

html body .ds-ingredients-page .ing-card:hover .ing-card-link .arrow {
  transform: translateX(4px);
}

/* ============ DISCLAIMER ============ */

html body .ds-ingredients-page .disclaimer {
  max-width: 760px;
  margin: 0 auto;
  text-align: center;
  font-size: 13px !important;
  line-height: 1.6 !important;
  color: #8A8A8A !important;
  padding: 0 0 80px;
}

</style>

<main class="ds-ingredients-page">

  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">What's inside.</h1>
      <p class="hero-sub">Eight actives. Every one fully dosed and fully disclosed. Tap any ingredient to see the research, the dose, and the role it plays.</p>
    </div>
  </section>

  <!-- ============ GRID ============ -->
  <div class="container">
    <div class="ing-grid">

      <a href="/pages/lions-mane" class="ing-card">
        <div class="ing-card-img">{% if img_lions_mane != blank %}<img src="{{ img_lions_mane }}" alt="Lion's Mane" width="600" height="600" loading="lazy">{% endif %}</div>
        <div class="ing-card-body">
          <h2 class="ing-card-name">Lion's Mane</h2>
          <p class="ing-card-desc">A functional mushroom studied for mental clarity and long-term cognitive support.</p>
          <span class="ing-card-link">Learn more <span class="arrow">&rarr;</span></span>
        </div>
      </a>

      <a href="/pages/alpha-gpc" class="ing-card">
        <div class="ing-card-img">{% if img_alpha_gpc != blank %}<img src="{{ img_alpha_gpc }}" alt="Alpha-GPC" width="600" height="600" loading="lazy">{% endif %}</div>
        <div class="ing-card-body">
          <h2 class="ing-card-name">Alpha-GPC</h2>
          <p class="ing-card-desc">A choline source studied for its role in focus and memory.</p>
          <span class="ing-card-link">Learn more <span class="arrow">&rarr;</span></span>
        </div>
      </a>

      <a href="/pages/caffeine" class="ing-card">
        <div class="ing-card-img">{% if img_caffeine != blank %}<img src="{{ img_caffeine }}" alt="Caffeine from green tea" width="600" height="600" loading="lazy">{% endif %}</div>
        <div class="ing-card-body">
          <h2 class="ing-card-name">Caffeine</h2>
          <p class="ing-card-desc">Clean caffeine from green tea, for sharp, alert energy.</p>
          <span class="ing-card-link">Learn more <span class="arrow">&rarr;</span></span>
        </div>
      </a>

      <a href="/pages/l-theanine" class="ing-card">
        <div class="ing-card-img">{% if img_l_theanine != blank %}<img src="{{ img_l_theanine }}" alt="L-Theanine" width="600" height="600" loading="lazy">{% endif %}</div>
        <div class="ing-card-body">
          <h2 class="ing-card-name">L-Theanine</h2>
          <p class="ing-card-desc">An amino acid that pairs with caffeine to support calm, smooth focus.</p>
          <span class="ing-card-link">Learn more <span class="arrow">&rarr;</span></span>
        </div>
      </a>

      <a href="/pages/cordyceps" class="ing-card">
        <div class="ing-card-img">{% if img_cordyceps != blank %}<img src="{{ img_cordyceps }}" alt="Cordyceps" width="600" height="600" loading="lazy">{% endif %}</div>
        <div class="ing-card-body">
          <h2 class="ing-card-name">Cordyceps</h2>
          <p class="ing-card-desc">An adaptogenic mushroom studied for energy and physical stamina.</p>
          <span class="ing-card-link">Learn more <span class="arrow">&rarr;</span></span>
        </div>
      </a>

      <a href="/pages/nalt" class="ing-card">
        <div class="ing-card-img">{% if img_nalt != blank %}<img src="{{ img_nalt }}" alt="N-Acetyl L-Tyrosine" width="600" height="600" loading="lazy">{% endif %}</div>
        <div class="ing-card-body">
          <h2 class="ing-card-name">N-Acetyl L-Tyrosine</h2>
          <p class="ing-card-desc">A tyrosine source that supports the body's production of dopamine.</p>
          <span class="ing-card-link">Learn more <span class="arrow">&rarr;</span></span>
        </div>
      </a>

      <a href="/pages/panax-ginseng" class="ing-card">
        <div class="ing-card-img">{% if img_panax != blank %}<img src="{{ img_panax }}" alt="Panax Ginseng" width="600" height="600" loading="lazy">{% endif %}</div>
        <div class="ing-card-body">
          <h2 class="ing-card-name">Panax Ginseng</h2>
          <p class="ing-card-desc">An adaptogen studied for mental stamina during sustained focus.</p>
          <span class="ing-card-link">Learn more <span class="arrow">&rarr;</span></span>
        </div>
      </a>

      <a href="/pages/rhodiola" class="ing-card">
        <div class="ing-card-img">{% if img_rhodiola != blank %}<img src="{{ img_rhodiola }}" alt="Rhodiola Rosea" width="600" height="600" loading="lazy">{% endif %}</div>
        <div class="ing-card-body">
          <h2 class="ing-card-name">Rhodiola Rosea</h2>
          <p class="ing-card-desc">An adaptogen that helps the body manage everyday stress.</p>
          <span class="ing-card-link">Learn more <span class="arrow">&rarr;</span></span>
        </div>
      </a>

    </div>

    <!-- ============ DISCLAIMER ============ -->
    <p class="disclaimer">These statements have not been evaluated by the Food and Drug Administration. This product is not intended to diagnose, treat, cure, or prevent any disease.</p>
  </div>

</main>