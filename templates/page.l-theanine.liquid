      }
    },
    {
      "@type": "Question",
      "name": "What is the 2:1 ratio of L-theanine to caffeine?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 2:1 ratio refers to two parts L-theanine to one part caffeine. This is the ratio used in the most-cited human trials on the combination, which have studied effects on reaction time, attention accuracy, and reduced over-stimulation versus caffeine alone. DayShift uses 240 mg L-theanine and 120 mg caffeine to match this ratio exactly."
      }
    },
    {
      "@type": "Question",
      "name": "Does L-theanine make you sleepy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. L-theanine is studied for promoting calm focus, not drowsiness. It is associated with alpha brain wave activity, the brain state of relaxed alertness, rather than the delta waves of deep sleep. When paired with caffeine, L-theanine supports clear, calm focus without sedation."
      }
    },
    {
      "@type": "Question",
      "name": "Is L-theanine safe?",
      "acceptedAnswer": {
        "@type": "Answer",
